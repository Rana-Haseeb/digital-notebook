# Server Configuration
PORT=5000

# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/database_name?retryWrites=true&w=majority

# JWT Secret for signing tokens (use a strong, random string)
JWT_SECRET=your_super_secret_key_here_change_this
